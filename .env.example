# ================================
# 环境变量配置示例
# 复制此文件为 .env 并修改相应的值
# ================================

# ==================
# Django 配置
# ==================
# Django密钥（使用 python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 生成）
SECRET_KEY=your-secret-key-here-change-this-in-production

# 调试模式（生产环境必须设置为False）
DEBUG=False

# 允许的主机（逗号分隔）
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ==================
# 数据库配置
# ==================
# 数据库引擎
DB_ENGINE=django.db.backends.postgresql

# 数据库名称
DB_NAME=memberdb

# 数据库用户
DB_USER=memberuser

# 数据库密码（必须修改）
DB_PASSWORD=your-strong-database-password-here

# 数据库主机
DB_HOST=localhost

# 数据库端口
DB_PORT=5432

# ==================
# Redis配置（可选）
# ==================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# ==================
# CORS配置
# ==================
# 允许的跨域来源（逗号分隔）
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==================
# JWT配置
# ==================
# 访问令牌有效期（分钟）
JWT_ACCESS_TOKEN_LIFETIME=60

# 刷新令牌有效期（分钟）
JWT_REFRESH_TOKEN_LIFETIME=1440

# ==================
# 邮件配置（可选）
# ==================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ==================
# 存储配置（可选）
# ==================
# AWS S3配置（用于存储静态文件和媒体文件）
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# ==================
# 日志配置
# ==================
# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 日志保留天数
LOG_RETENTION_DAYS=30

# ==================
# 监控配置（可选）
# ==================
# Sentry错误追踪
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=production

# ==================
# 前端环境变量
# ==================
# API基础URL
VITE_API_BASE_URL=https://api.yourdomain.com/api

# 应用标题
VITE_APP_TITLE=会员管理系统

# ==================
# 监控服务配置
# ==================
# Grafana管理员密码
GRAFANA_PASSWORD=admin-password-here

# ==================
# 其他配置
# ==================
# 时区
TIME_ZONE=Asia/Shanghai

# 语言代码
LANGUAGE_CODE=zh-hans

# 网站域名
DOMAIN=yourdomain.com

# SSL证书邮箱（用于Let's Encrypt）
SSL_EMAIL=your-email@example.com
